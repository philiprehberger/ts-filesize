{
  "name": "@philiprehberger/filesize",
  "version": "0.2.0",
  "description": "Human-readable file size formatting and parsing — bytes to KB, MB, GB and back",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "filesize",
    "bytes",
    "format",
    "human-readable",
    "parse",
    "size"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-filesize.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-filesize#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-filesize/issues"
  },
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
